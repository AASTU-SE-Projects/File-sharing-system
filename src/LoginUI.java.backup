import dao.UserDAO;
import javafx.animation.FadeTransition;
import javafx.animation.ScaleTransition;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.PasswordField;
import javafx.scene.control.TextField;
import javafx.scene.layout.StackPane;
import javafx.scene.layout.VBox;
import javafx.stage.Stage;
import javafx.util.Duration;
import model.User;
import rmi.RMIClient;
import rmi.UserServiceRemote;
import util.LaunchMode;

public class LoginUI extends Application {

    private static LaunchMode launchMode = LaunchMode.CLIENT;
    private final UserDAO userDAO = new UserDAO();
    private UserServiceRemote userService;

    public static void setLaunchMode(LaunchMode mode) {
        if (mode != null) {
            launchMode = mode;
        }
    }

    @Override
    public void start(Stage primaryStage) {
        try {
            System.out.println("🔗 [LoginUI] Attempting RMI connection...");
            RMIClient.initialize();
            userService = RMIClient.getUserService();
            System.out.println("✅ [LoginUI] RMI connection successful - using remote services");
        } catch (Exception e) {
            System.out.println("⚠️  [LoginUI] RMI not available, using local mode");
            System.out.println("   Error: " + e.getMessage());
            userService = null;
        }

        StackPane root = new StackPane();
        root.setStyle("-fx-background-color: linear-gradient(to bottom right, #f7f9fc, #d9e6f2 55%, #bed6ea);");

        VBox card = new VBox(14);
        card.setAlignment(Pos.CENTER_LEFT);
        card.setPadding(new Insets(36));
        card.setMaxWidth(420);
        card.setStyle("-fx-background-color: rgba(255,255,255,0.93);"
                + "-fx-background-radius: 18;"
                + "-fx-border-radius: 18;"
                + "-fx-border-color: rgba(26, 64, 96, 0.13);"
                + "-fx-effect: dropshadow(gaussian, rgba(18, 52, 86, 0.22), 28, 0.2, 0, 9);");

        Label miniHeading = new Label("Campus Share");
        miniHeading.setStyle("-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #395d7b;"
                + "-fx-background-color: #e6eef6; -fx-padding: 5 12 5 12; -fx-background-radius: 99;");

        Label title = new Label("Campus File Sharing");
        title.setStyle("-fx-font-size: 31px; -fx-font-weight: 800; -fx-text-fill: #18344b;");

        Label subtitle = new Label(launchMode == LaunchMode.SERVER ? "Server Instance" : "Client Instance");
        subtitle.setStyle("-fx-font-size: 14px; -fx-text-fill: #5e7387;");

        Label helperText = new Label("Sign in to upload, share, and manage your documents.");
        helperText.setStyle("-fx-font-size: 12px; -fx-text-fill: #7a8795;");

        TextField emailField = new TextField();
        emailField.setPromptText("Email Address");
        emailField.setPrefHeight(42);
        emailField.setStyle("-fx-font-size: 14px; -fx-background-radius: 12; -fx-border-radius: 12;"
                + "-fx-border-color: #cad8e5; -fx-background-color: #f8fbfe;");

        PasswordField passwordField = new PasswordField();
        passwordField.setPromptText("Password");
        passwordField.setPrefHeight(42);
        passwordField.setStyle("-fx-font-size: 14px; -fx-background-radius: 12; -fx-border-radius: 12;"
                + "-fx-border-color: #cad8e5; -fx-background-color: #f8fbfe;");

        Button loginButton = new Button("Login");
        loginButton.setMaxWidth(Double.MAX_VALUE);
        loginButton.setPrefHeight(44);
        loginButton.setStyle("-fx-background-color: linear-gradient(to right, #1d6fa6, #2458a7);"
                + "-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700;"
                + "-fx-background-radius: 12; -fx-cursor: hand;");

        Button registerButton = new Button("Create New Account");
        registerButton.setMaxWidth(Double.MAX_VALUE);
        registerButton.setPrefHeight(40);
        registerButton.setStyle("-fx-background-color: #edf3f9; -fx-text-fill: #204d74;"
                + "-fx-font-size: 13px; -fx-font-weight: 600; -fx-background-radius: 10; -fx-cursor: hand;");

        Label statusLabel = new Label();
        statusLabel.setWrapText(true);
        statusLabel.setStyle("-fx-text-fill: #b02a37; -fx-font-size: 12px;");

        VBox layout = new VBox(10, miniHeading, title, subtitle, helperText, emailField, passwordField, loginButton,
                registerButton, statusLabel);
        layout.setAlignment(Pos.CENTER_LEFT);
        card.getChildren().add(layout);
        root.getChildren().add(card);

        addCardEntrance(card);

        loginButton.setOnMouseEntered(
                e -> loginButton.setStyle("-fx-background-color: linear-gradient(to right, #1b6394, #204f95);"
                        + "-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700;"
                        + "-fx-background-radius: 12; -fx-cursor: hand;"));
        loginButton.setOnMouseExited(
                e -> loginButton.setStyle("-fx-background-color: linear-gradient(to right, #1d6fa6, #2458a7);"
                        + "-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700;"
                        + "-fx-background-radius: 12; -fx-cursor: hand;"));

        loginButton.setOnAction(e -> loginUser(primaryStage, emailField, passwordField, statusLabel));

        registerButton.setOnAction(e -> {
            primaryStage.close();
            new RegisterUI().start(new Stage());
        });

        Scene scene = new Scene(root, 560, 520);
        primaryStage.setTitle((launchMode == LaunchMode.SERVER ? "Server" : "Client") + " Login - Campus File Sharing");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    private void addCardEntrance(VBox card) {
        card.setOpacity(0);
        card.setScaleX(0.96);
        card.setScaleY(0.96);

        FadeTransition fade = new FadeTransition(Duration.millis(460), card);
        fade.setFromValue(0);
        fade.setToValue(1);

        ScaleTransition scale = new ScaleTransition(Duration.millis(460), card);
        scale.setFromX(0.96);
        scale.setFromY(0.96);
        scale.setToX(1.0);
        scale.setToY(1.0);

        fade.play();
        scale.play();
    }

    private void loginUser(Stage stage, TextField emailField, PasswordField passwordField, Label statusLabel) {
        String email = emailField.getText().trim();
        String password = passwordField.getText();

        if (email.isEmpty() || password.isEmpty()) {
            statusLabel.setStyle("-fx-text-fill: red; -fx-font-size: 13px;");
            statusLabel.setText("Please enter email and password.");
            return;
        }

        try {
            User user;

            if (userService != null && RMIClient.isConnected()) {
                System.out.println("📡 [LoginUI] Using RMI: Calling remote loginUser()");
                user = userService.loginUser(email, password);
            } else {
                System.out.println("💾 [LoginUI] Using Local: Calling local login()");
                user = userDAO.login(email, password);
            }

            if (user != null) {
                System.out.println("✅ [LoginUI] Login successful: " + user.getUsername());
                statusLabel.setStyle("-fx-text-fill: green; -fx-font-size: 13px;");
                statusLabel.setText("Login Success - Opening Dashboard...");

                stage.close();
                DashboardUI dashboard = new DashboardUI(user);
                dashboard.start(new Stage());
            } else {
                statusLabel.setStyle("-fx-text-fill: red; -fx-font-size: 13px;");
                statusLabel.setText("Invalid email or password.");
            }
        } catch (Exception ex) {
            System.err.println("❌ [LoginUI] Login error: " + ex.getMessage());
            statusLabel.setStyle("-fx-text-fill: red; -fx-font-size: 13px;");
            statusLabel.setText("Login failed: " + ex.getMessage());
        }
    }

    public static void main(String[] args) {
        launch(args);
    }
}
